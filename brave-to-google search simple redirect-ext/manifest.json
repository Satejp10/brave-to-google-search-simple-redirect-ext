{
  "manifest_version": 3,
  "name": "Search on Google – Brave to Google Redirect",
  "version": "1.0.0",
  "description": "Adds a Google button on Brave Search to quickly search the same query on Google.",
  "permissions": [],
  "content_scripts": [
    {
      "matches": ["https://search.brave.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
